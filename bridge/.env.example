# Bridge server environment variables — copy to bridge/.env and fill in values
#
# Public HTTPS URL where this bridge is reachable (via Cloudflare Tunnel).
# Must match VITE_BRIDGE_URL in .env.production
PUBLIC_BRIDGE_URL=https://bridge.soord.org.uk

# Port the bridge HTTP server listens on (default: 5174)
BRIDGE_PORT=5174

# Set to 1 to log all SlimProto commands to stdout
BRIDGE_LOG_COMMANDS=0
